{
  "name": "@napi-rs/lzma",
  "version": "1.4.5",
  "description": "https://docs.rs/lzma-rs binding to Node.js via https://napi.rs",
  "napi": {
    "binaryName": "lzma",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "aarch64-linux-android",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "armv7-unknown-linux-gnueabihf",
      "arm-linux-androideabi",
      "x86_64-unknown-linux-musl",
      "x86_64-unknown-freebsd",
      "i686-pc-windows-msvc",
      "wasm32-wasi-preview1-threads",
      "powerpc64le-unknown-linux-gnu",
      "s390x-unknown-linux-gnu",
      "riscv64gc-unknown-linux-gnu"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "url": "git+https://github.com/Brooooooklyn/lzma.git",
    "type": "git"
  },
  "keywords": [
    "Node-API",
    "napi",
    "lzma",
    "compress",
    "decompress",
    "xz",
    "napi-rs"
  ],
  "license": "MIT",
  "files": [
    "index.js",
    "index.d.ts",
    "main.js",
    "xz.js",
    "xz.d.ts",
    "xz.browser.js",
    "xz.browser.d.ts",
    "lzma.js",
    "lzma.d.ts",
    "lzma.browser.js",
    "lzma.browser.d.ts",
    "lzma2.js",
    "lzma2.d.ts",
    "lzma2.browser.js",
    "lzma2.browser.d.ts",
    "stream-polyfill.js",
    "stream-polyfill.mjs",
    "browser-entry.js"
  ],
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@napi-rs/cli": "^3.1.3",
    "@napi-rs/wasm-runtime": "^1.1.4",
    "@oxc-node/core": "^0.1.0",
    "@taplo/cli": "^0.7.0",
    "@types/lzma-native": "^4.0.4",
    "@types/node": "^24.2.1",
    "ava": "^8.0.0",
    "conventional-changelog-cli": "^5.0.0",
    "lzma": "^2.3.2",
    "lzma-native": "^8.0.6",
    "npm-run-all2": "^9.0.0",
    "oxlint": "^1.11.1",
    "prettier": "^3.6.2",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": "^22.20 || ^24.12 || >=25"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "lint": "oxlint .",
    "format": "run-p format:source format:rs format:toml",
    "format:rs": "cargo fmt",
    "format:source": "prettier --config ./package.json --write .",
    "format:toml": "taplo format",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "version": "napi version && conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md"
  },
  "ava": {
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ],
    "extensions": [
      "ts"
    ],
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "TS_NODE_PROJECT": "./tsconfig.json",
      "NODE_ENV": "ava"
    }
  },
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "trailingComma": "all",
    "singleQuote": true,
    "arrowParens": "always"
  },
  "browser": {
    "index.js": "./browser-entry.js",
    "main.js": "./browser-entry.js",
    "xz.js": "./xz.browser.js",
    "lzma.js": "./lzma.browser.js",
    "lzma2.js": "./lzma2.browser.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "browser": "./browser-entry.js",
      "import": "./main.js",
      "require": "./main.js"
    },
    "./xz": {
      "browser": {
        "types": "./xz.browser.d.ts",
        "import": "./xz.browser.js"
      },
      "types": "./xz.d.ts",
      "import": "./xz.js",
      "require": "./xz.js"
    },
    "./lzma": {
      "browser": {
        "types": "./lzma.browser.d.ts",
        "import": "./lzma.browser.js"
      },
      "types": "./lzma.d.ts",
      "import": "./lzma.js",
      "require": "./lzma.js"
    },
    "./lzma2": {
      "browser": {
        "types": "./lzma2.browser.d.ts",
        "import": "./lzma2.browser.js"
      },
      "types": "./lzma2.d.ts",
      "import": "./lzma2.js",
      "require": "./lzma2.js"
    }
  },
  "packageManager": "yarn@4.17.0",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Brooooooklyn"
  }
}
